rules_version = '2';

// Firebase Storage Security Rules para Winbit App
service firebase.storage {
  match /b/{bucket}/o {
    
    // Función helper para verificar que el usuario está autenticado
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Función helper para verificar el tamaño del archivo (máx 5MB)
    function isValidSize() {
      return request.resource.size < 5 * 1024 * 1024;
    }
    
    // Función helper para verificar el tipo de archivo
    function isValidFileType() {
      return request.resource.contentType.matches('image/(jpeg|jpg|png|webp)')
          || request.resource.contentType == 'application/pdf';
    }
    
    // Reglas para la carpeta "deposits"
    match /deposits/{fileName} {
      // Lectura solo para usuarios autenticados (admin o Google login)
      allow read: if isAuthenticated();

      // Escritura sin requerir auth: inversores con login por email no tienen
      // sesión Firebase Auth. Los nombres son únicos (timestamp + random) y
      // se validan tipo y tamaño para evitar abuso.
      allow write: if isValidSize() && isValidFileType();
    }
    
    // Denegar acceso a cualquier otra ruta no especificada
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
